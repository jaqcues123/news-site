# ─── Admin Auth ────────────────────────────────────────────
# Password required to access /admin
ADMIN_PASSWORD=changeme

# ─── GitHub API (required for production admin CRUD) ───────
# Create a fine-grained PAT with "Contents: Read & Write" on this repo
GITHUB_TOKEN=
GITHUB_OWNER=jaqcues123
GITHUB_REPO=news-site
GITHUB_BRANCH=main

# ─── Email (Resend) ─────────────────────────────────────────
# Get a free API key at resend.com (3,000 emails/month free)
RESEND_API_KEY=
# Where inquiry emails get sent
SALES_EMAIL=sales@netruckcenter.com
# Verified sender domain in Resend
FROM_EMAIL=noreply@netruckcenter.com
